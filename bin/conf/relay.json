{
  "log": {
    "file": "logs/relay.log",
    "error_file": "logs/relay.error.log",
    "level": "info",
    "console": true,
    "syslog": false,
    "rotate": {
      "mode": "size",
      "max_size": 10485760,
      "max_files": 5,
      "daily_hour": 0,
      "daily_minute": 0
    }
  },
  "relay": {
    "instance_id": 1,
    "listen": {
      "host": "127.0.0.1",
      "port": 9200
    },
    "discovery": {
      "endpoints": [
        "127.0.0.1:2379"
      ],
      "prefix": "/some_server/ipc/dev/local",
      "lease_ttl_seconds": 5
    }
  }
}
